# Modal credentials (get from modal.com dashboard)
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret

# Amigo API credentials (for system events)
AMIGO_API_BASE_URL=https://api.amigo.ai
AMIGO_API_KEY=your-amigo-api-key

# Anthropic API credentials (for agent-driven tool generation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Tool Foundry configuration
FOUNDRY_ENVIRONMENT=development
FOUNDRY_API_BASE_URL=https://your-workspace--tool-foundry-foundry-api.modal.run
FOUNDRY_AGENT_MODEL=claude-sonnet-4-20250514

# Feature flags (optional - defaults shown)
# FOUNDRY_ENABLE_SANDBOX_EXECUTION=true
# FOUNDRY_ENABLE_ASYNC_BUILDS=true
# FOUNDRY_ENABLE_EVENT_EMISSION=true
