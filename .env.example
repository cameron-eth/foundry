# =============================================================================
# Foundry Environment Variables (for local development only)
# Modal deployments use `modal secret create` instead — see README.md
# =============================================================================

# LLM Provider (at least one required)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Web Search (optional — enables /v1/search endpoint)
BRAVE_API_KEY=

# Exa Search (optional — alternative search provider)
EXA_API_KEY=

# Database (optional — enables auth, usage tracking, billing)
# Only needed if you want multi-tenant API key management
DATABASE_URL=

# Autumn Billing (optional — enables usage-based billing via Stripe)
AUTUMN_SECRET_KEY=

# Foundry Configuration
FOUNDRY_ENVIRONMENT=development
FOUNDRY_REQUIRE_AUTH=false
FOUNDRY_LLM_PROVIDER=anthropic
FOUNDRY_AGENT_MODEL=claude-sonnet-4-20250514
